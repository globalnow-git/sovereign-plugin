[08-Jun-2026 23:25:56 UTC] WordPress database error Unknown column 'updated_at' in 'field list' for query INSERT INTO `wp_sb_templates` (`template_key`, `from_name`, `from_email`, `subject`, `content_type`, `body`, `created_at`, `updated_at`) VALUES ('upsell_path_sequence_2', 'Sovereign Builder Dev', 'greg@grianna.com', 'A question for you, {{first_name}}', 'text/html', '\n<p>Hi {{first_name}},</p>\n\n<p>Quick question — and I\'d genuinely like to know the answer.</p>\n\n<p>What\'s the gap between where you are right now and where you want to be?</p>\n\n<p>Not a big philosophical answer. Just: what\'s the one thing that if it were solved, would make the biggest difference in the next 90 days?</p>\n\n<p>Reply and tell me. I read every one.</p>\n\n<p>I ask because I want to make sure what we\'re offering next is actually the right fit for you — and that means knowing where you\'re stuck.</p>\n\n<p>When you reply, I\'ll respond with something specific. Not a sales pitch. A real answer.</p>\n\n<p>Talk soon,<br>\nThe Team at {{site_url}}</p>\n\n<p style=\"font-size:11px;color:#999\">\n<a href=\"{{unsubscribe_url}}\">Unsubscribe</a>\n</p>\n				', '2026-06-08 23:25:56', '2026-06-08 23:25:56') made by require('wp-blog-header.php'), require_once('wp-load.php'), require_once('wp-config.php'), require_once('wp-settings.php'), do_action('init'), WP_Hook->do_action, WP_Hook->apply_filters, SB_Content_Seeder::init, SB_Content_Seeder::seed_all, SB_Content_Seeder::seed_email_templates
