  "pipeline": {
    "slug": "book-authorship-pipeline",
    "label": "Book Development & Authorship Pipeline",
    "steps": [
      {
        "step": 1,
        "role": "Story Analyst",
        "instruction": "When a story_vision_submitted signal arrives, analyze the author's complete story vision (2000-5000 words). Extract key characters mentioned, world-building elements, central conflicts, themes, and the intended ending. Identify any gaps or areas where character development would strengthen the narrative. Generate a list of 3-7 major characters that need detailed development based on the vision. Store this analysis and trigger the character development stage. Do NOT generate content — only analyze what the author has created and identify characters for development."
      },
      {
        "step": 2,
        "role": "Character Development Assistant",
        "instruction": "When character_developed signal arrives, review the author's character notes and ask 3-5 thoughtful questions about the character's motivations, arc, voice, relationships, and role in the story. Questions should help the author deepen their creative decisions, not make decisions for them. Store questions in ai_feedback_received field for the next round. Track discussion rounds. When the author provides responses, acknowledge them and either ask follow-up questions (if needed) or signal that the character is ready for finalization."
      },
      {
        "step": 3,
        "role": "Character Finalization Coordinator",
        "instruction": "When character_finalized signal arrives, compile all discussion rounds for that character into a comprehensive profile that reflects only the author's stated decisions. Log the finalization with timestamp. Track how many characters have been finalized versus how many were identified in step 1. When all characters are finalized, trigger chapter structure proposal."
      },
      {
        "step": 4,
        "role": "Structure Architect",
        "instruction": "When all characters are finalized, generate a proposed chapter structure based on the author's story vision, character arcs, and target word count. Break the story into logical chapters with brief descriptions of what each chapter should accomplish narratively. Present this structure in the chapter-structure-review-form's ai_proposed_structure field. Wait for author to edit and approve. Do NOT proceed until chapter_structure_approved signal is received."
      },
      {
        "step": 5,
        "role": "Chapter Draft Generator",
        "instruction": "When chapter_direction_given signal arrives, read the author's specific directions, voice examples, and requirements for that chapter. Generate a draft chapter that follows their instructions precisely. The draft should match their target word count (+/- 10%) and incorporate any specific dialogue, scenes, or elements they specified. Place draft in ai_draft field of chapter-approval-form. Log that chapter_draft_generated signal occurred. Wait for author approval."
      },
      {
        "step": 6,
        "role": "Edit Logger",
        "instruction": "When chapter_approved signal arrives, compare the ai_draft with the author_edits field to identify all changes the author made. Log each category of edit (dialogue changes, description additions, plot modifications, voice adjustments, etc.) as discrete author decisions in the authorship timeline. Calculate edit volume metrics (percentage changed, number of additions/deletions). Store the final approved chapter. Track chapter completion count."
      },
      {
        "step": 7,
        "role": "Completion Coordinator",
        "instruction": "Monitor chapter progress. When all chapters from the approved structure have received chapter_approved signals, enable the book-completion-form. When book_declared_complete signal arrives, compile the complete book into a clean DOCX file (final approved text only, properly formatted with chapters). Simultaneously generate the HITM (Human-In-The-Middle) authorship log DOCX containing: story vision, all character development rounds and decisions, structure approval with edits, every chapter direction, every draft-to-final comparison showing author edits, edit metrics, and the completion certification. Both files should be timestamped and cryptographically signed. Trigger authorship_certificate_generated signal and make downloads available."
      },
      {
        "step": 8,
        "role": "Authorship Certification Generator",
        "instruction": "When authorship_certificate_generated signal fires, create a comprehensive certificate document that includes: author name, book title, completion date, total chapters, final word count, total logged decision points, summary statistics (number of character discussions, structure edits, chapter revisions, total words edited), and a certification statement that reads: 'This certificate verifies that [Author Name] made every creative decision in the development of [Book Title]. While AI assistance was used for drafting, this log demonstrates human authorship through documented creative direction, character development, structural decisions, and comprehensive editing throughout the process. Certificate generated [timestamp] with cryptographic signature [hash].' Include QR code linking to verification page."
      }
    ]
  }
}