{
  "slug": "book-development-authorship-portal",
  "label": "Book Development & Authorship Portal",
  "version": "1.0.0",
  "category": "saas",
  "blueprint_type": "vertical-app",
  "description": "A portal where authors develop books with AI assistance while maintaining an immutable log of every human creative decision as proof of authentic authorship.",
  "signals": [
    "story_vision_submitted",
    "character_developed",
    "character_finalized",
    "chapter_structure_proposed",
    "chapter_structure_approved",
    "chapter_direction_given",
    "chapter_draft_generated",
    "chapter_approved",
    "book_declared_complete",
    "authorship_certificate_generated"
  ],
  "roads": [
    {
      "road_key": "A",
      "label": "Story Vision"
    },
    {
      "road_key": "B",
      "label": "Character Development"
    },
    {
      "road_key": "C",
      "label": "Chapter Structure"
    },
    {
      "road_key": "D",
      "label": "Chapter Writing"
    },
    {
      "road_key": "E",
      "label": "Completion & Export"
    }
  ],
  "forms": [
    {
      "slug": "story-vision-form",
      "label": "Story Vision Submission",
      "save_adapter": "submission_table",
      "save_config_json": {
        "signal_type": "story_vision_submitted"
      },
      "fields_json": [
        {
          "key": "book_title",
          "label": "Working Book Title",
          "type": "text",
          "required": true,
          "placeholder": "Enter your working title"
        },
        {
          "key": "genre",
          "label": "Genre",
          "type": "select",
          "required": true,
          "options": [
            "Literary Fiction",
            "Science Fiction",
            "Fantasy",
            "Mystery/Thriller",
            "Romance",
            "Historical Fiction",
            "Young Adult",
            "Non-Fiction",
            "Memoir",
            "Other"
          ]
        },
        {
          "key": "story_vision",
          "label": "Complete Story Vision (2000-5000 words minimum)",
          "type": "textarea",
          "required": true,
          "placeholder": "Write your complete creative vision: world, characters, conflict, themes, and the ending you're working toward. This is NOT a prompt for AI — this is YOUR full story concept in detail.",
          "validation": {
            "min_words": 2000,
            "max_words": 5000
          }
        },
        {
          "key": "target_word_count",
          "label": "Target Book Word Count",
          "type": "number",
          "required": true,
          "placeholder": "e.g., 80000"
        },
        {
          "key": "authorship_declaration",
          "label": "Authorship Declaration",
          "type": "checkbox",
          "required": true,
          "options": [
            "I confirm this story vision is my original creative work and I will maintain creative control throughout development"
          ]
        }
      ]
    },
    {
      "slug": "character-discussion-form",
      "label": "Character Discussion Round",
      "save_adapter": "submission_table",
      "save_config_json": {
        "signal_type": "character_developed"
      },
      "fields_json": [
        {
          "key": "character_name",
          "label": "Character Name",
          "type": "text",
          "required": true,
          "placeholder": "Full character name"
        },
        {
          "key": "character_role",
          "label": "Character Role",
          "type": "select",
          "required": true,
          "options": [
            "Protagonist",
            "Antagonist",
            "Supporting Character",
            "Minor Character"
          ]
        },
        {
          "key": "author_character_notes",
          "label": "Your Character Development Notes",
          "type": "textarea",
          "required": true,
          "placeholder": "Describe who this character is, their arc, motivations, voice, and role in the story"
        },
        {
          "key": "ai_feedback_received",
          "label": "AI Feedback/Questions (read-only reference)",
          "type": "textarea",
          "required": false,
          "readonly": true
        },
        {
          "key": "author_responses",
          "label": "Your Responses to AI Questions",
          "type": "textarea",
          "required": true,
          "placeholder": "Answer AI questions and clarify your creative decisions about this character"
        },
        {
          "key": "discussion_round",
          "label": "Discussion Round Number",
          "type": "number",
          "required": true,
          "default": 1
        }
      ]
    },
    {
      "slug": "character-finalization-form",
      "label": "Character Finalization",
      "save_adapter": "submission_table",
      "save_config_json": {
        "signal_type": "character_finalized"
      },
      "fields_json": [
        {
          "key": "character_name",
          "label": "Character Name",
          "type": "text",
          "required": true,
          "readonly": true
        },
        {
          "key": "final_character_profile",
          "label": "Final Character Profile",
          "type": "textarea",
          "required": true,
          "placeholder": "Your approved final character profile"
        },
        {
          "key": "author_approval",
          "label": "Author Approval",
          "type": "checkbox",
          "required": true,
          "options": [
            "I approve this character profile and all creative decisions are mine"
          ]
        },
        {
          "key": "approval_timestamp",
          "label": "Approval Timestamp",
          "type": "datetime",
          "required": true,
          "auto_populate": "current_timestamp"
        }
      ]
    },
    {
      "slug": "chapter-structure-review-form",
      "label": "Chapter Structure Review",
      "save_adapter": "submission_table",
      "save_config_json": {
        "signal_type": "chapter_structure_approved"
      },
      "fields_json": [
        {
          "key": "ai_proposed_structure",
          "label": "AI-Proposed Chapter Structure (read-only)",
          "type": "textarea",
          "required": false,
          "readonly": true
        },
        {
          "key": "author_edits",
          "label": "Your Edits to Chapter Structure",
          "type": "textarea",
          "required": true,
          "placeholder": "Edit, reorganize, add or remove chapters as needed. This is YOUR structure."
        },
        {
          "key": "final_chapter_count",
          "label": "Final Chapter Count",
          "type": "number",
          "required": true,
          "placeholder": "Total number of chapters"
        },
        {
          "key": "structure_approval",
          "label": "Structure Approval",
          "type": "checkbox",
          "required": true,
          "options": [
            "I approve this chapter structure and it reflects my creative vision"
          ]
        },
        {
          "key": "approval_timestamp",
          "label": "Approval Timestamp",
          "type": "datetime",
          "required": true,
          "auto_populate": "current_timestamp"
        }
      ]
    },
    {
      "slug": "chapter-direction-form",
      "label": "Chapter Direction & Instructions",
      "save_adapter": "submission_table",
      "save_config_json": {
        "signal_type": "chapter_direction_given"
      },
      "fields_json": [
        {
          "key": "chapter_number",
          "label": "Chapter Number",
          "type": "number",
          "required": true,
          "placeholder": "e.g., 1"
        },
        {
          "key": "chapter_title",
          "label": "Chapter Title",
          "type": "text",
          "required": true,
          "placeholder": "Enter chapter title"
        },
        {
          "key": "chapter_directions",
          "label": "Your Directions for This Chapter",
          "type": "textarea",
          "required": true,
          "placeholder": "Describe what happens in this chapter, key scenes, character moments, and any specific narrative directions"
        },
        {
          "key": "voice_examples",
          "label": "Voice Examples or Style Notes (optional)",
          "type": "textarea",
          "required": false,
          "placeholder": "Provide examples of your desired voice, tone, or specific stylistic instructions"
        },
        {
          "key": "specific_requirements",
          "label": "Specific Requirements",
          "type": "textarea",
          "required": false,
          "placeholder": "Any dialogue, scenes, or elements that MUST be included exactly as you specify"
        },
        {
          "key": "target_word_count",
          "label": "Target Word Count for Chapter",
          "type": "number",
          "required": true,
          "placeholder": "e.g., 3000"
        }
      ]
    },
    {
      "slug": "chapter-approval-form",
      "label": "Chapter Draft Review & Approval",
      "save_adapter": "submission_table",
      "save_config_json": {
        "signal_type": "chapter_approved"
      },
      "fields_json": [
        {
          "key": "chapter_number",
          "label": "Chapter Number",
          "type": "number",
          "required": true,
          "readonly": true
        },
        {
          "key": "ai_draft",
          "label": "AI-Generated Draft (read-only)",
          "type": "textarea",
          "required": false,
          "readonly": true
        },
        {
          "key": "author_edits",
          "label": "Your Edits and Revisions",
          "type": "textarea",
          "required": true,
          "placeholder": "Edit the draft as needed. All edits are logged as your creative decisions."
        },
        {
          "key": "revision_notes",
          "label": "Revision Notes",
          "type": "textarea",
          "required": false,
          "placeholder": "Document what you changed and why"
        },
        {
          "key": "chapter_approval",
          "label": "Chapter Approval",
          "type": "checkbox",
          "required": true,
          "options": [
            "I approve this chapter and all creative decisions and edits are mine"
          ]
        },
        {
          "key": "approval_timestamp",
          "label": "Approval Timestamp",
          "type": "datetime",
          "required": true,
          "auto_populate": "current_timestamp"
        }
      ]
    },
    {
      "slug": "book-completion-form",
      "label": "Book Completion Declaration",
      "save_adapter": "submission_table",
      "save_config_json": {
        "signal_type": "book_declared_complete"
      },
      "fields_json": [
        {
          "key": "final_book_title",
          "label": "Final Book Title",
          "type": "text",
          "required": true,
          "placeholder": "Enter final title"
        },
        {
          "key": "completion_statement",
          "label": "Completion Statement",
          "type": "textarea",
          "required": true,
          "placeholder": "Write a brief statement about your creative journey and the completion of this work"
        },
        {
          "key": "total_chapters",
          "label": "Total Chapters Completed",
          "type": "number",
          "required": true,
          "readonly": true
        },
        {
          "key": "final_word_count",
          "label": "Final Word Count",
          "type": "number",
          "required": true,
          "readonly": true
        },
        {
          "key": "authorship_certification",
          "label": "Authorship Certification",
          "type": "checkbox",
          "required": true,
          "options": [
            "I certify that every creative decision in this book is mine, and this log represents my authentic authorship process"
          ]
        },
        {
          "key": "completion_timestamp",
          "label": "Completion Timestamp",
          "type": "datetime",
          "required": true,
          "auto_populate": "current_timestamp"
        }
      ]
    }
  ],
